---
import { siteConfig } from "../config";

const navItems = [
  { href: "#top", label: "Intro" },
  { href: "#featured-projects", label: "Projects" },
  { href: "#management-layer", label: "Management" },
  { href: "#full-archive", label: "Archive" },
];
---

<header
  id="header"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-500"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 md:px-8">
    <a href="#top" class="flex items-center gap-2">
      <strong class="text-sm uppercase tracking-[0.28em] text-white">{siteConfig.englishName}</strong>
    </a>

    <!-- 데스크탑 메뉴 -->
    <ul class="hidden items-center gap-6 lg:flex">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm font-medium text-white/68 transition hover:text-white"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- 모바일 햄버거 버튼 -->
    <button
      id="mobile-menu-btn"
      type="button"
      aria-label="메뉴 열기"
      class="flex flex-col gap-1.5 p-2 lg:hidden"
    >
      <span class="hamburger-line block h-0.5 w-6 bg-white transition-all duration-300"></span>
      <span class="hamburger-line block h-0.5 w-6 bg-white transition-all duration-300"></span>
      <span class="hamburger-line block h-0.5 w-6 bg-white transition-all duration-300"></span>
    </button>
  </nav>

  <!-- 모바일 드로어 -->
  <div
    id="mobile-drawer"
    class="hidden border-t border-white/10 bg-black/95 backdrop-blur-xl px-5 pb-6 pt-4 lg:hidden"
  >
    <ul class="flex flex-col gap-4">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="mobile-nav-link block text-base font-medium text-white/70 transition hover:text-white"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const syncHeader = () => {
    const header = document.getElementById("header");
    if (!header) return;
    if (window.scrollY > 24) {
      header.classList.add("bg-black/72", "backdrop-blur-xl", "shadow-[0_18px_45px_rgba(0,0,0,0.32)]");
    } else {
      header.classList.remove("bg-black/72", "backdrop-blur-xl", "shadow-[0_18px_45px_rgba(0,0,0,0.32)]");
    }
  };

  syncHeader();
  window.addEventListener("scroll", syncHeader, { passive: true });

  // 햄버거 메뉴 토글
  const btn = document.getElementById("mobile-menu-btn");
  const drawer = document.getElementById("mobile-drawer");

  btn?.addEventListener("click", () => {
    const isOpen = !drawer?.classList.contains("hidden");
    if (isOpen) {
      drawer?.classList.add("hidden");
    } else {
      drawer?.classList.remove("hidden");
    }
  });

  // 메뉴 링크 클릭 시 닫기
  drawer?.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      drawer.classList.add("hidden");
    });
  });
</script>

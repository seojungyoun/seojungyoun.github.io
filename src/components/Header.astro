---
import { siteConfig } from "../config";

const navItems = [
  { href: "#workflow", label: "Workflow" },
  { href: "#logic-layer", label: "Logic Layer" },
  { href: "#management-layer", label: "Management" },
  { href: "#foundation", label: "Foundation" },
  { href: siteConfig.archive.hiddenPageHref, label: "Hidden Page" },
];
---

<header
  id="header"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-500"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 md:px-8">
    <a href="#top" class="flex items-center gap-3 text-[var(--navy)]">
      <span class="grid h-11 w-11 place-items-center rounded-2xl border border-white/60 bg-white/70 text-sm font-semibold shadow-[0_12px_30px_rgba(31,47,99,0.14)] backdrop-blur">
        SJ
      </span>
      <span class="hidden md:block">
        <strong class="block text-sm uppercase tracking-[0.28em]">{siteConfig.englishName}</strong>
        <span class="block text-xs text-[var(--muted)]">AI-Human Pipeline</span>
      </span>
    </a>

    <ul class="hidden items-center gap-6 lg:flex">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm font-medium text-[var(--navy)]/80 transition hover:text-[var(--navy)]"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href={siteConfig.archive.reviewerSummaryHref}
      class="rounded-full border border-[var(--pink-strong)]/40 bg-[var(--pink-soft)] px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-[var(--navy)] transition hover:-translate-y-0.5 hover:bg-white"
    >
      Reviewer PDF
    </a>
  </nav>
</header>

<script>
  const syncHeader = () => {
    const header = document.getElementById("header");
    if (!header) return;

    if (window.scrollY > 24) {
      header.classList.add("bg-white/78", "backdrop-blur-xl", "shadow-[0_18px_45px_rgba(31,47,99,0.12)]");
    } else {
      header.classList.remove("bg-white/78", "backdrop-blur-xl", "shadow-[0_18px_45px_rgba(31,47,99,0.12)]");
    }
  };

  syncHeader();
  window.addEventListener("scroll", syncHeader, { passive: true });
</script>

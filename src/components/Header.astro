---
import { siteConfig } from "../config";

const navItems = [
  { href: "#top", label: "Intro" },
  { href: "#featured-projects", label: "Projects" },
  { href: "#management-layer", label: "Management" },
  { href: "#full-archive", label: "Archive" },
  { href: siteConfig.archive.hiddenPageHref, label: "SM Proposal" },
];
---

<header
  id="header"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-500"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 md:px-8">
    <a href="#top" class="flex items-center gap-2">
      <strong class="text-sm uppercase tracking-[0.28em] text-[var(--navy-900)]">{siteConfig.englishName}</strong>
    </a>

    <ul class="hidden items-center gap-6 lg:flex">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm font-medium text-[var(--navy)]/80 transition hover:text-[var(--navy)]"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

  </nav>
</header>

<script>
  const syncHeader = () => {
    const header = document.getElementById("header");
    if (!header) return;

    if (window.scrollY > 24) {
      header.classList.add("bg-white/78", "backdrop-blur-xl", "shadow-[0_18px_45px_rgba(31,47,99,0.12)]");
    } else {
      header.classList.remove("bg-white/78", "backdrop-blur-xl", "shadow-[0_18px_45px_rgba(31,47,99,0.12)]");
    }
  };

  syncHeader();
  window.addEventListener("scroll", syncHeader, { passive: true });
</script>

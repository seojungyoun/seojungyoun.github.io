---
import { siteConfig } from "../config";

const socialEntries = [
  { label: "Email", href: siteConfig.social.email ? `mailto:${siteConfig.social.email}` : undefined },
  { label: "LinkedIn", href: siteConfig.social.linkedin },
  { label: "GitHub", href: siteConfig.social.github },
].filter((entry) => entry.href);
---

<footer class="relative overflow-hidden border-t border-[var(--line)] bg-[var(--cream)] px-6 py-12 text-[var(--ink)]">

  <div class="relative mx-auto max-w-7xl flex flex-col items-center gap-6 text-center">

    <div>
      <p class="text-xl font-bold text-[var(--ink)]">{siteConfig.name}</p>
    </div>

    <div class="flex flex-wrap justify-center gap-3">
      {
        socialEntries.map((entry) => (
          <a
            href={entry.href}
            target={entry.label === "Email" ? undefined : "_blank"}
            rel={entry.label === "Email" ? undefined : "noreferrer"}
            class="rounded-full border border-[var(--line)] bg-white/55 px-5 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--ink)]/70 transition hover:border-[var(--ink)] hover:text-[var(--ink)]"
          >
            {entry.label}
          </a>
        ))
      }
    </div>

    <p class="text-xs text-[var(--ink)]/35 uppercase tracking-[0.22em]">
      © {new Date().getFullYear()} Seo Jungyoun. Portfolio.
    </p>

  </div>
</footer>

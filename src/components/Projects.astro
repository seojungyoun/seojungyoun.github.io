---
import { siteConfig } from "../config";
const projects = siteConfig.highlightProjects || [];
const hasProjects = projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Projects
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-12">
              {projects.map((project, index) => {
                // 유튜브 URL 자동 변환 및 판별 로직
                let videoSrc = project.video;
                const isYoutube = videoSrc?.includes('youtube.com') || videoSrc?.includes('youtu.be');
                
                if (isYoutube && videoSrc && !videoSrc.includes('embed')) {
                  const videoId = videoSrc.split('v=')[1]?.split('&')[0] || videoSrc.split('/').pop();
                  videoSrc = `https://www.youtube.com/embed/${videoId}`;
                }

                return (
                  <div class="group relative bg-gray-50 rounded-2xl border border-gray-200 p-6 md:p-10 transition-all duration-300 hover:bg-white hover:shadow-2xl">
                    <div class="space-y-6">
                      <div class="flex justify-between items-start">
                        <div>
                          <span class="text-sm font-mono" style={{ color: siteConfig.accentColor }}>
                            0{index + 1}
                          </span>
                          <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mt-1">
                            {project.title}
                          </h3>
                          <p class="text-sm text-gray-500 font-medium mt-1">{project.subtitle}</p>
                        </div>
                        
                        {project.status && (
                          <span class="px-3 py-1 bg-pink-50 text-pink-500 text-xs font-bold rounded-full border border-pink-100">
                            {project.status}
                          </span>
                        )}
                      </div>

                      <p class="text-gray-600 leading-relaxed text-lg">
                        {project.summary}
                      </p>

                      {/* 영상 렌더링 섹션 */}
                      {videoSrc && (
                        <div class="aspect-video w-full rounded-xl overflow-hidden shadow-inner bg-black border border-gray-200">
                          {isYoutube ? (
                            <iframe
                              src={videoSrc}
                              class="w-full h-full"
                              title={`${project.title} Video`}
                              frameborder="0"
                              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                              referrerpolicy="strict-origin-when-cross-origin"
                              allowfullscreen
                            ></iframe>
                          ) : (
                            <video src={videoSrc} controls class="w-full h-full object-cover"></video>
                          )}
                        </div>
                      )}

                      {/* 기술 스택 표시 (config.ts의 stack 필드 사용) */}
                      {project.stack && project.stack.length > 0 && (
                        <div class="flex flex-wrap gap-2 pt-4">
                          {project.stack.map((item) => (
                            <span class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium">
                              {item}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}